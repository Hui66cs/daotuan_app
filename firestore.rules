rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidModule(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.summary is string && data.summary.size() < 2000 &&
             data.text is string && data.text.size() < 50000 &&
             data.images is list && data.images.size() <= 50 &&
             data.children is list && data.children.size() <= 100;
    }

    match /modules/{moduleId} {
      // For this collaborative workspace, we allow all authenticated users to read and write
      // In a production app, you might want to restrict this to specific users or groups
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidModule(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
